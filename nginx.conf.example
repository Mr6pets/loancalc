# LoanCalc 部署 Nginx 配置
# 已集成到 d:\GitHubStore\loancalc\nginx\conf.d\includes\99_static_subdomains.conf
# 此文件仅作参考

# 前端静态文件（SPA）
location ^~ /loancalc {
    alias /home/loancalc/dist/;
    index index.html;
    try_files $uri $uri/ /loancalc/index.html;
}

# API 反向代理到 Node 服务（端口 3002）
location ^~ /loancalc/api/ {
    proxy_pass http://127.0.0.1:3002/api/;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}
