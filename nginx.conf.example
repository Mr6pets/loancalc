# 阿里云 Nginx 配置示例
# 将 dist/ 上传到 /var/www/loan-calc/
# API 服务运行在 3001 端口

server {
    listen 80;
    server_name your-domain.com;

    root /var/www/loan-calc/dist;
    index index.html;

    # 前端静态文件
    location / {
        try_files $uri $uri/ /index.html;
    }

    # API 反向代理到 Node 服务
    location /api/ {
        proxy_pass http://127.0.0.1:3001;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # PWA 图标
    location ~ /(manifest\.json|icon\.svg|sw\.js)$ {
        try_files $uri =404;
    }
}
