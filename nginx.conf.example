# LoanCalc 部署 Nginx 配置（宝塔面板 + Docker）
# 前端静态文件由宝塔网站管理，后端 Node.js 由 Docker 运行
# 完整配置见: nginx/conf.d/includes/03_loadcalc.conf

# 前端静态文件（SPA）
location ^~ /loancalc {
    alias /www/wwwroot/loancalc/h5/;
    index index.html;
    try_files $uri $uri/ /loancalc/index.html;
}

# API 反向代理到 Docker 容器（端口 3002）
location ^~ /loancalc/api/ {
    proxy_pass http://127.0.0.1:3002/api/;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}
